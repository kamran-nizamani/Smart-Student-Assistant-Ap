rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'kamrannizamani35@gmail.com'; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.email is string &&
             data.role in ['student', 'teacher', 'admin'] &&
             (!('dailyGoalMinutes' in data) || data.dailyGoalMinutes is number) &&
             (!('createdAt' in data) || data.createdAt is number);
    }

    function isValidNote(data) {
      return data.keys().hasAll(['userId', 'title', 'content']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 10000;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['userId', 'content']) &&
             data.userId == request.auth.uid &&
             data.content is string && data.content.size() <= 500;
    }

    function isValidQuiz(data) {
      return data.keys().hasAll(['title', 'subject', 'createdBy']) &&
             data.title is string && data.subject is string &&
             data.createdBy == request.auth.uid;
    }

    function isValidResult(data) {
      return data.keys().hasAll(['studentId', 'quizId', 'score', 'totalQuestions', 'teacherId']) &&
             data.studentId == request.auth.uid &&
             data.score is number && data.totalQuestions is number &&
             data.teacherId is string;
    }

    function isValidAssignment(data) {
      return data.keys().hasAll(['title', 'subject', 'teacherId', 'totalPoints']) &&
             data.teacherId == request.auth.uid &&
             data.title is string && data.totalPoints is number;
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['assignmentId', 'studentId', 'content']) &&
             data.studentId == request.auth.uid &&
             data.content is string;
    }

    // --- Routes ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) && isValidUser(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'subjects', 'dailyGoalMinutes']))
                    || isAdmin();
    }

    match /notes/{noteId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidNote(incoming()) && isValidId(noteId);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidNote(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidTask(incoming()) && isValidId(taskId);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && (
        incoming().diff(existing()).affectedKeys().hasOnly(['completed', 'content'])
      );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /quizzes/{quizId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidQuiz(incoming());
      allow update, delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    match /results/{resultId} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.teacherId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidResult(incoming());
    }

    match /assignments/{asgnId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isValidAssignment(incoming()) || isAdmin());
      allow update, delete: if isSignedIn() && (resource.data.teacherId == request.auth.uid || isAdmin());
    }

    match /submissions/{subId} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.teacherId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidSubmission(incoming());
      allow update: if isSignedIn() && (
        (resource.data.teacherId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'score', 'feedback']))
        || isAdmin()
      );
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin() || (isSignedIn() && incoming().userId == request.auth.uid);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }

    match /grades/{gradeId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /progress/{progressId} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
    }
  }
}
